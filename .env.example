# Local LLM Agent — environment variables template
# Copy to `.env` and edit. `.env` is gitignored.

# Ollama backend
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gemma3:12b

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.jsonl

# (Phase 2+) optional external services
# CHROMA_DB_PATH=data/chroma
